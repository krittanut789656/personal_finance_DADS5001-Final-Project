# ============================================================
# Streamlit Secrets Template
# ============================================================
# For Streamlit Community Cloud deployment.
#
# Do NOT commit a real "secrets.toml" to GitHub - it is already covered by
# .gitignore. On Streamlit Community Cloud, paste the contents of this file
# (with real values filled in) into:
#
#   App settings -> Secrets
#
# `common/bootstrap.py` copies these keys into `os.environ` on startup, so
# `backend/config/settings.py` (which reads `os.environ`) picks them up
# automatically - no code changes needed between local `.env` and Cloud
# secrets.
#
# Every key below is OPTIONAL. With no keys set, the app runs fully
# functional in offline / Non-AI mode (DuckDB + local CSV, rules-based
# pages 5-7).
# ============================================================

# ---------- MongoDB Atlas ----------
MONGODB_URI = "mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority"
MONGODB_DATABASE = "personal_finance_db"

# ---------- Snowflake ----------
SNOWFLAKE_ACCOUNT = "mj18661"
SNOWFLAKE_USER = ""
SNOWFLAKE_PASSWORD = ""
SNOWFLAKE_ROLE = "ACCOUNTADMIN"
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_DATABASE = "PERSONAL_FINANCE_DB"
SNOWFLAKE_SCHEMA = "PUBLIC"

# ---------- DuckDB ----------
DUCKDB_PATH = ":memory:"

# ---------- Data ----------
RAW_DATA_PATH = "backend/data/raw/Expenses_clean.csv"

# ---------- Logging ----------
LOG_LEVEL = "INFO"
LOG_DIR = "logs"

# ---------- AI (Anthropic Claude) - Phase 4 ----------
# Leave unset for Non-AI Mode (pages 5-7 still fully usable, rules-based).
ANTHROPIC_API_KEY = ""
AI_MODEL = "claude-sonnet-4-6"
AI_MAX_TOKENS = "1024"

# ---------- FRED (Federal Reserve Economic Data) - Phase 4 ----------
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Leave unset to skip macro context (CPI, Fed funds rate, unemployment).
FRED_API_KEY = ""
FRED_BASE_URL = "https://api.stlouisfed.org/fred"
